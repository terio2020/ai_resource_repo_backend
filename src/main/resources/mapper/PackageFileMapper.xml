<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.PackageFileMapper">

    <resultMap id="BaseResultMap" type="com.ai.repo.entity.PackageFile">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="uid" property="uid" jdbcType="VARCHAR"/>
        <result column="version_id" property="versionId" jdbcType="BIGINT"/>
        <result column="file_name" property="fileName" jdbcType="VARCHAR"/>
        <result column="file_path" property="filePath" jdbcType="VARCHAR"/>
        <result column="file_size" property="fileSize" jdbcType="BIGINT"/>
        <result column="mime_type" property="mimeType" jdbcType="VARCHAR"/>
        <result column="md5_hash" property="md5Hash" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        uid, id, version_id, file_name, file_path, file_size, mime_type, md5_hash, created_at
    </sql>

    <insert id="insert" parameterType="com.ai.repo.entity.PackageFile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO package_files (uid, version_id, file_name, file_path, file_size, mime_type, md5_hash, created_at)
        VALUES (#{uid}, #{versionId}, #{fileName}, #{filePath}, #{fileSize}, #{mimeType}, #{md5Hash}, #{createdAt})
    </insert>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO package_files (uid, version_id, file_name, file_path, file_size, mime_type, md5_hash, created_at)
        VALUES
        <foreach collection="files" item="f" separator=",">
            (#{f.uid}, #{f.versionId}, #{f.fileName}, #{f.filePath}, #{f.fileSize}, #{f.mimeType}, #{f.md5Hash}, #{f.createdAt})
        </foreach>
    </insert>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM package_files WHERE id = #{id}
    </select>

    <select id="selectByVersionId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM package_files WHERE version_id = #{versionId}
        ORDER BY file_path ASC
    </select>

    <delete id="deleteByVersionId" parameterType="java.lang.Long">
        DELETE FROM package_files WHERE version_id = #{versionId}
    </delete>

    <select id="selectByUid" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM package_files
        WHERE uid = #{uid}
    </select>

</mapper>

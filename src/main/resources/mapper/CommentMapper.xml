<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="com.ai.repo.entity.Comment">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="agent_id" property="agentId" jdbcType="BIGINT"/>
        <result column="skill_id" property="skillId" jdbcType="BIGINT"/>
        <result column="memory_id" property="memoryId" jdbcType="BIGINT"/>
        <result column="parent_id" property="parentId" jdbcType="BIGINT"/>
        <result column="content" property="content" jdbcType="LONGVARCHAR"/>
        <result column="like_count" property="likeCount" jdbcType="INTEGER"/>
        <result column="reply_count" property="replyCount" jdbcType="INTEGER"/>
        <result column="downvote_count" property="downvoteCount" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>
 
    <sql id="Base_Column_List">
        id, agent_id, skill_id, memory_id, parent_id, content,
        like_count, reply_count, downvote_count, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.ai.repo.entity.Comment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comments (agent_id, skill_id, memory_id, parent_id, content, like_count, reply_count, downvote_count)
        VALUES (#{agentId}, #{skillId}, #{memoryId}, #{parentId}, #{content}, #{likeCount}, #{replyCount}, #{downvoteCount})
    </insert>

    <update id="update" parameterType="com.ai.repo.entity.Comment">
        UPDATE comments
        SET agent_id = #{agentId},
            skill_id = #{skillId},
            memory_id = #{memoryId},
            parent_id = #{parentId},
            content = #{content},
            like_count = #{likeCount},
            reply_count = #{replyCount},
            downvote_count = #{downvoteCount}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM comments WHERE id = #{id}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        ORDER BY created_at DESC
    </select>

    <select id="selectByAgentId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        WHERE agent_id = #{agentId}
        ORDER BY created_at DESC
    </select>

    <select id="selectBySkillId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        WHERE skill_id = #{skillId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByMemoryId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        WHERE memory_id = #{memoryId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByParentId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        WHERE parent_id = #{parentId}
        ORDER BY created_at ASC
    </select>

    <select id="selectRootComments" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM comments
        WHERE parent_id IS NULL
        <if test="skillId != null">
            AND skill_id = #{skillId}
        </if>
        <if test="memoryId != null">
            AND memory_id = #{memoryId}
        </if>
        ORDER BY created_at DESC
    </select>
 
</mapper>

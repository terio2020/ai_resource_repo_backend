<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.CommentMapper">

    <resultMap id="BaseResultMap" type="com.ai.repo.entity.Comment">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="uid" property="uid" jdbcType="VARCHAR"/>
        <result column="agent_id" property="agentId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
        <result column="repo_id" property="repoId" jdbcType="BIGINT"/>
        <result column="memory_id" property="memoryId" jdbcType="BIGINT"/>
        <result column="parent_id" property="parentId" jdbcType="BIGINT"/>
        <result column="content" property="content" jdbcType="LONGVARCHAR"/>
        <result column="like_count" property="likeCount" jdbcType="INTEGER"/>
        <result column="reply_count" property="replyCount" jdbcType="INTEGER"/>
        <result column="downvote_count" property="downvoteCount" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>
 
    <sql id="Base_Column_List">
        c.uid, c.id, c.agent_id, a.user_id, COALESCE(a.display_name, a.name) AS username,
        c.repo_id, c.memory_id, c.parent_id, c.content,
        c.like_count, c.reply_count, c.downvote_count, c.created_at, c.updated_at
    </sql>

    <sql id="FromClause">
        FROM comments c
        LEFT JOIN agents a ON c.agent_id = a.id
    </sql>

    <insert id="insert" parameterType="com.ai.repo.entity.Comment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO comments (uid, agent_id, repo_id, memory_id, parent_id, content, like_count, reply_count, downvote_count)
        VALUES (#{uid}, #{agentId}, #{repoId}, #{memoryId}, #{parentId}, #{content}, #{likeCount}, #{replyCount}, #{downvoteCount})
    </insert>

    <update id="update" parameterType="com.ai.repo.entity.Comment">
        UPDATE comments
        <set>
            <if test="agentId != null">agent_id = #{agentId},</if>
            <if test="repoId != null">repo_id = #{repoId},</if>
            <if test="memoryId != null">memory_id = #{memoryId},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="content != null">content = #{content},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="replyCount != null">reply_count = #{replyCount},</if>
            <if test="downvoteCount != null">downvote_count = #{downvoteCount},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM comments WHERE id = #{id}
    </delete>

    <delete id="deleteByAgentId" parameterType="java.lang.Long">
        DELETE FROM comments WHERE agent_id = #{agentId}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        ORDER BY c.created_at DESC
    </select>

    <select id="selectByAgentId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.agent_id = #{agentId}
        ORDER BY c.created_at DESC
    </select>

    <select id="selectByRepoId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.repo_id = #{repoId}
        ORDER BY c.created_at DESC
    </select>

    <select id="selectByMemoryId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.memory_id = #{memoryId}
        ORDER BY c.created_at DESC
    </select>

    <select id="selectByParentId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.parent_id = #{parentId}
        ORDER BY c.created_at ASC
    </select>

    <select id="selectRootComments" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.parent_id IS NULL
        <if test="repoId != null">
            AND c.repo_id = #{repoId}
        </if>
        <if test="memoryId != null">
            AND c.memory_id = #{memoryId}
        </if>
        ORDER BY c.created_at DESC
    </select>

    <update id="incrementLikeCount">
        UPDATE comments
        SET like_count = like_count + 1
        WHERE id = #{id}
    </update>
 
    <select id="selectByUid" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        <include refid="FromClause"/>
        WHERE c.uid = #{uid}
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.CircleSubscriptionMapper">
 
    <resultMap id="BaseResultMap" type="com.ai.repo.entity.CircleSubscription">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="agent_id" property="agentId" jdbcType="BIGINT"/>
        <result column="circle_id" property="circleId" jdbcType="BIGINT"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>
 
    <sql id="Base_Column_List">
        id, agent_id, circle_id, created_at
    </sql>
 
    <insert id="insert" parameterType="com.ai.repo.entity.CircleSubscription" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO circle_subscriptions (agent_id, circle_id)
        VALUES (#{agentId}, #{circleId})
    </insert>
 
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM circle_subscriptions WHERE id = #{id}
    </delete>
 
    <delete id="deleteByAgentCircle">
        DELETE FROM circle_subscriptions WHERE agent_id = #{agentId} AND circle_id = #{circleId}
    </delete>
 
    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM circle_subscriptions
        WHERE id = #{id}
    </select>
 
    <select id="selectByAgentCircle" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM circle_subscriptions
        WHERE agent_id = #{agentId} AND circle_id = #{circleId}
    </select>
 
    <select id="selectByAgentId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM circle_subscriptions
        WHERE agent_id = #{agentId}
        ORDER BY created_at DESC
    </select>
 
    <select id="selectByCircleId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM circle_subscriptions
        WHERE circle_id = #{circleId}
        ORDER BY created_at DESC
    </select>
 
    <select id="countByAgentId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT COUNT(*) FROM circle_subscriptions WHERE agent_id = #{agentId}
    </select>
 
    <select id="countByCircleId" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT COUNT(*) FROM circle_subscriptions WHERE circle_id = #{circleId}
    </select>
 
</mapper>
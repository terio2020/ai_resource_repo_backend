<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.SocialAccountMapper">

    <resultMap id="BaseResultMap" type="com.ai.repo.entity.SocialAccount">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="uid" property="uid" jdbcType="VARCHAR"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="provider" property="provider" jdbcType="VARCHAR"/>
        <result column="provider_user_id" property="providerUserId" jdbcType="VARCHAR"/>
        <result column="access_token" property="accessToken" jdbcType="VARCHAR"/>
        <result column="refresh_token" property="refreshToken" jdbcType="VARCHAR"/>
        <result column="email" property="email" jdbcType="VARCHAR"/>
        <result column="nickname" property="nickname" jdbcType="VARCHAR"/>
        <result column="avatar" property="avatar" jdbcType="VARCHAR"/>
        <result column="token_expires_at" property="tokenExpiresAt" jdbcType="TIMESTAMP"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        uid, id, user_id, provider, provider_user_id, access_token, refresh_token,
        email, nickname, avatar, token_expires_at, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.ai.repo.entity.SocialAccount" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO social_accounts (uid, user_id, provider, provider_user_id, access_token, refresh_token,
                                          email, nickname, avatar, token_expires_at, created_at, updated_at)
        VALUES (#{uid}, #{userId}, #{provider}, #{providerUserId}, #{accessToken}, #{refreshToken},
                #{email}, #{nickname}, #{avatar}, #{tokenExpiresAt}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.ai.repo.entity.SocialAccount">
        UPDATE social_accounts
        SET access_token = #{accessToken},
            refresh_token = #{refreshToken},
            email = #{email},
            nickname = #{nickname},
            avatar = #{avatar},
            token_expires_at = #{tokenExpiresAt},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM social_accounts WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId" parameterType="java.lang.Long">
        DELETE FROM social_accounts WHERE user_id = #{userId}
    </delete>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM social_accounts
        WHERE id = #{id}
    </select>

    <select id="selectByProviderAndProviderUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM social_accounts
        WHERE provider = #{provider} AND provider_user_id = #{providerUserId}
    </select>

    <select id="selectByUserIdAndProvider" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM social_accounts
        WHERE user_id = #{userId} AND provider = #{provider}
    </select>

    <select id="selectByUserId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM social_accounts
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <select id="selectByProvider" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM social_accounts
        WHERE provider = #{provider}
        ORDER BY created_at DESC
    </select>

    <select id="selectByUid" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM social_accounts
        WHERE uid = #{uid}
    </select>

</mapper>
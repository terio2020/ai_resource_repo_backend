<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.ContributionFileMapper">

    <resultMap id="BaseResultMap" type="com.ai.repo.entity.ContributionFile">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="contribution_id" property="contributionId" jdbcType="BIGINT"/>
        <result column="file_name" property="fileName" jdbcType="VARCHAR"/>
        <result column="file_path" property="filePath" jdbcType="VARCHAR"/>
        <result column="file_size" property="fileSize" jdbcType="BIGINT"/>
        <result column="md5_hash" property="md5Hash" jdbcType="VARCHAR"/>
        <result column="storage_path" property="storagePath" jdbcType="VARCHAR"/>
        <result column="action" property="action" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, contribution_id, file_name, file_path, file_size, md5_hash, storage_path, action, created_at
    </sql>

    <insert id="insert" parameterType="com.ai.repo.entity.ContributionFile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO contribution_files (contribution_id, file_name, file_path, file_size, md5_hash, storage_path, action, created_at)
        VALUES (#{contributionId}, #{fileName}, #{filePath}, #{fileSize}, #{md5Hash}, #{storagePath}, #{action}, #{createdAt})
    </insert>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO contribution_files (contribution_id, file_name, file_path, file_size, md5_hash, storage_path, action, created_at)
        VALUES
        <foreach collection="files" item="f" separator=",">
            (#{f.contributionId}, #{f.fileName}, #{f.filePath}, #{f.fileSize}, #{f.md5Hash}, #{f.storagePath}, #{f.action}, #{f.createdAt})
        </foreach>
    </insert>

    <select id="selectByContributionId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM contribution_files WHERE contribution_id = #{contributionId}
    </select>

    <delete id="deleteByContributionId" parameterType="java.lang.Long">
        DELETE FROM contribution_files WHERE contribution_id = #{contributionId}
    </delete>

</mapper>

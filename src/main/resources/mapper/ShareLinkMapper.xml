<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.repo.mapper.ShareLinkMapper">

    <resultMap id="BaseResultMap" type="com.ai.repo.entity.ShareLink">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="uid" property="uid" jdbcType="VARCHAR"/>
        <result column="skill_id" property="skillId" jdbcType="BIGINT"/>
        <result column="share_token" property="shareToken" jdbcType="VARCHAR"/>
        <result column="created_by" property="createdBy" jdbcType="BIGINT"/>
        <result column="view_count" property="viewCount" jdbcType="INTEGER"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        uid, id, skill_id, share_token, created_by, view_count, created_at
    </sql>

    <insert id="insert" parameterType="com.ai.repo.entity.ShareLink" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO share_links (uid, skill_id, share_token, created_by, view_count)
        VALUES (#{uid}, #{skillId}, #{shareToken}, #{createdBy}, #{viewCount})
    </insert>

    <select id="findByToken" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM share_links
        WHERE share_token = #{token}
    </select>

    <select id="findBySkillAndCreator" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM share_links
        WHERE skill_id = #{skillId} AND created_by = #{createdBy}
        LIMIT 1
    </select>

    <update id="incrementViewCount">
        UPDATE share_links SET view_count = view_count + 1 WHERE id = #{id}
    </update>

    <select id="selectByUid" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM share_links
        WHERE uid = #{uid}
    </select>

</mapper>

# ==========================================
# 邮件服务配置
# ==========================================
# 复制这份文件为 .env 并填入真实值
# .env 文件不会被提交到 git

# SMTP 配置
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@logicoma.ai

# 应用URL配置（用于生成邮件中的链接）
APP_BASE_URL=http://your-api-domain.com
APP_FRONTEND_URL=http://your-frontend-domain.com

# ==========================================
# OAuth2 社交登录配置
# ==========================================
# Google OAuth
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/oauth/google/callback

# GitHub OAuth
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:8080/api/oauth/github/callback

# Apple OAuth（可选）
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY=
OAUTH_APPLE_REDIRECT_URI=http://localhost:8080/api/oauth/apple/callback

# OAuth 状态加密密钥（生产环境请修改）
APP_OAUTH_STATE_SECRET=change-this-secret-in-production
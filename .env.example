# ==========================================
# 邮件服务配置
# ==========================================
# 复制这份文件为 .env 并填入真实值
# .env 文件不会被提交到 git

# SMTP 配置
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@logicoma.ai

# 应用URL配置（用于生成邮件中的链接）
APP_BASE_URL=http://your-api-domain.com
APP_FRONTEND_URL=http://your-frontend-domain.com